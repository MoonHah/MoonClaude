# MoonClaude 环境配置模板
# 用法：cp .env.example .env，然后按需修改

# ── Core Daemon ───────────────────────────────────────────────
MOON_HOST=127.0.0.1
MOON_PORT=7437

# ── Logging ───────────────────────────────────────────────────
MOON_LOG_LEVEL=INFO
# 留空则仅输出 stderr，不写文件
MOON_LOG_FILE=~/.moon/logs/core.log
# text（人工可读键值对）或 json（结构化，适合日志聚合）
MOON_LOG_FORMAT=text

# ── Config File ───────────────────────────────────────────────
# 设置后只读取指定的 TOML 配置文件
# MOON_CONFIG=~/.moon/config.toml

# ── LLM（S1 阶段启用）────────────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...
# MOON_LLM_MODEL=claude-sonnet-4-6
# MOON_MAX_STEPS=20
